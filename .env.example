# Non-secret config. Copy to .env and fill in values.
# POSTGRES_PASSWORD is no longer stored here — it lives in AWS SSM (/leonard/prod/POSTGRES_PASSWORD).
CADDY_HOST=

# Bearer token for all non-health API routes (local dev: leave empty for open access).
# In prod, read from /run/secrets/api_token (Docker secret from AWS SSM) by the backend,
# and exported as REACT_APP_API_TOKEN by deploy-prod.sh for the frontend build arg.
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
API_TOKEN=
REACT_APP_API_TOKEN=

# Fernet key for CDR credential encryption at rest (local dev / CI fallback only).
# In prod, the key is read from /run/secrets/cdr_fernet_key (Docker secret mounted from AWS SSM).
# Generate a new key: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CDR_FERNET_KEY=

# Pre-baked HAPI FHIR images — contains all 12 connectathon bundles pre-loaded in the H2 database.
# Requires GHCR auth: docker login ghcr.io (GitHub account with Bellese org access).
# See docs/runbooks/ghcr-pull-auth.md for auth setup.
# Leave IMAGE vars unset to use vanilla hapiproject/hapi:v8.8.0-1 (no auth needed, slower start).
HAPI_CDR_IMAGE=ghcr.io/bellese/lenny-hapi-cdr:latest
HAPI_MEASURE_IMAGE=ghcr.io/bellese/lenny-hapi-measure:latest

# Use the prebaked compose overlay so Docker reads H2 data baked into the image
# instead of mounting an empty volume over it. Required when using HAPI_*_IMAGE above.
# Remove this line (or comment it out) if falling back to vanilla HAPI images.
COMPOSE_FILE=docker-compose.yml:docker-compose.prebaked.yml
